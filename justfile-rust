# # has more than one entry. Mirror removals in uninstall.
#
# # --- run helpers (media-forge, pika, nvprime client) ---
# run *args:
#     cargo run --release -- {{args}}
#
# # --- debug build (only if someone still wants it; not the default) ---
# build-debug:
#     cargo build
#
# # --- bespoke test gate (llama.rs: exclude live tests from `test`) ---
# test:
#     cargo test --lib --test cli --test api
#
# test-live:
#     cargo test --test live_server
#
# # --- systemd / daemon extras (nvprime, compose-utils) live *beside* baseline
# # install, they do not replace it. Example:
# install-service: install
#     ./system/install.sh install-service
#
# # --- container / coverage (wsmr) live *beside* baseline; keep recipe names
# # that already mean something else in that repo only if they don't collide.
# # Prefer renaming local `check`/`lint` aliases if they conflict with baseline
# # semantics (baseline `check` = fmt-check + lint + test).
