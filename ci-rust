# Canonical GitHub Actions CI for personal Rust *binary* projects that ship
# a `justfile` from `justfile-rust`.
#
# Copy to:  .github/workflows/ci.yml
#
# Contract (must match JUST.md R8 + justfile-rust baseline):
#
#   just format --check-only   rustfmt check          (not `fmt-check` / `fmt`)
#   just lint                  clippy -D warnings
#   cargo build --all-targets  compile every target
#   just test                  safe unit gate only    (test_unit; no flags)
#
# Why not `just build` in CI?
#   Default `just build` = host-native release (`-C target-cpu=native`) + upx.
#   That needs upx on the runner, is non-portable, and is not an --all-targets
#   compile. CI compile gate stays raw cargo. Local ship path stays `just build`
#   / `just install`.
#
# Why not `just full-gate` alone?
#   full-gate = format --check-only + lint + test (correct local one-shot).
#   Split steps keep separate annotations in the Actions UI. full-gate also
#   omits the --all-targets compile — CI keeps that extra cargo step.
#
# Never in default CI:
#   just test --integration / --run-all   (live services / credentials)
#   just build                            (native + upx)
#   just build --debug                    (not --all-targets)
#
# Policy: JUST.md + justfile-rust (rules → baseline → layers → exceptions).
# - System deps (media-forge, …): uncomment the apt step below rust-cache.
# - Libraries without a justfile (plex-rs): raw cargo only — do not use this file.
# - Exception workflows (docker, release, wsmr container jobs) stay separate.

name: ci

on:
  push:
    branches: [main]
  pull_request:
  workflow_dispatch:

concurrency:
  group: ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5

      - uses: extractions/setup-just@v4

      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy

      - uses: Swatinem/rust-cache@v2

      # Optional — only for crates that need native libs at build time:
      # - name: System build dependencies
      #   run: |
      #     sudo apt-get update
      #     sudo apt-get install -y <packages>

      - name: format
        run: just format --check-only

      - name: lint
        run: just lint

      - name: build
        run: cargo build --all-targets --verbose

      - name: test
        run: just test
